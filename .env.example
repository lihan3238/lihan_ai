# Copy to .env and replace every CHANGE_ME value before deployment.
DOMAIN=api.example.com
ACME_EMAIL=ops@example.com
TZ=Asia/Shanghai

NEW_API_IMAGE=calciumion/new-api:latest
NODE_NAME=relay-v1-hk-1
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_64_RANDOM_CHARS

POSTGRES_USER=newapi
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD_32_RANDOM_CHARS
POSTGRES_DB=newapi
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_32_RANDOM_CHARS

# Operating policy flags for runbooks and automation.
INVITE_ONLY=true
PAYMENT_MODE=manual_confirmation
DEFAULT_MODEL_POOL=standard
ECONOMY_POOL_ENABLED=true
CACHE_OBSERVABILITY_ENABLED=true

KUMA_PORT=3001
NEW_API_DEV_PORT=3000
BACKUP_RETENTION_DAYS=14
