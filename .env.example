DEPLOY_ENV=local
DEPLOY_COMPOSE_PROJECT=lihan_ai
LIHAN_AI_NETWORK=lihan_ai_relay-internal
TZ=Asia/Shanghai

NEW_API_IMAGE=calciumion/new-api:latest
POSTGRES_IMAGE=postgres:15-alpine@sha256:3d0f7584ed7d04e27fa050d6683a74746608faf21f202be78460d679cc56461f
REDIS_IMAGE=redis:7-alpine@sha256:6ab0b6e7381779332f97b8ca76193e45b0756f38d4c0dcda72dbb3c32061ab99
CLI_PROXY_IMAGE=eceasy/cli-proxy-api:latest
CLOUDFLARED_IMAGE=cloudflare/cloudflared:latest

NODE_NAME=relay-local
SESSION_SECRET=CHANGE_ME_LOCAL_SESSION_SECRET

POSTGRES_USER=newapi
POSTGRES_PASSWORD=CHANGE_ME_LOCAL_POSTGRES_PASSWORD
POSTGRES_DB=newapi
REDIS_PASSWORD=CHANGE_ME_LOCAL_REDIS_PASSWORD

CPA_CONFIG_PATH=./data/cpa/config.yaml
CPA_AUTH_PATH=./data/cpa
CPA_LOG_PATH=./logs/cpa
CPA_BIND_IP=127.0.0.1
CPA_UI_PORT=8317
CPA_DEPLOY=

CLOUDFLARED_CONFIG_PATH=./cloudflared/config.yml
CLOUDFLARED_CREDENTIALS_PATH=./cloudflared/tunnel.json

BACKUP_DIR=./backups
CONFIG_BACKUP_DIR=./snapshots/config
