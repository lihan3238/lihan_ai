# Copy to .env.production on the production origin server.
# Replace every CHANGE_ME value before deployment.
DEPLOY_ENV=production
DOMAIN=api.example.com
ACME_EMAIL=ops@example.com
TZ=Asia/Shanghai

NEW_API_IMAGE=calciumion/new-api:latest
LOCAL_NEW_API_IMAGE=lihan-ai/new-api:local
NODE_NAME=relay-prod-origin-1
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_64_RANDOM_CHARS

POSTGRES_USER=newapi
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD_32_RANDOM_CHARS
POSTGRES_DB=newapi
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_32_RANDOM_CHARS

# Optional CPA / CLIProxyAPI integration. Keep real CPA config outside git.
CLI_PROXY_IMAGE=eceasy/cli-proxy-api:latest
CPA_CONFIG_PATH=/opt/lihan_ai_deploy/shared/data/cpa/config.yaml
CPA_AUTH_PATH=/opt/lihan_ai_deploy/shared/data/cpa
CPA_PUBLIC_PATH=/opt/lihan_ai_deploy/shared/data/cpa/public
CPA_LOG_PATH=/opt/lihan_ai_deploy/shared/logs/cpa
CPA_UI_PORT=8317

BACKUP_RETENTION_DAYS=30
BACKUP_KEEP=30
BACKUP_MAX_TOTAL_MB=2048
BACKUP_CRON_LOG_DIR=logs
BACKUP_CRON_LOG_MAX_MB=10
BACKUP_CRON_LOG_KEEP=5
CONFIG_SNAPSHOT_DIR=snapshots/config
CONFIG_SNAPSHOT_KEEP=30
CONFIG_SNAPSHOT_MAX_TOTAL_MB=256
CONFIG_SNAPSHOT_GPG_RECIPIENT=

# Local wrapper defaults. Keep real SSH targets in your shell, not in git.
DEPLOY_HOST=
DEPLOY_PATH=/opt/lihan_ai
DEPLOY_ROOT=/opt/lihan_ai_deploy
DEPLOY_REF=main
DEPLOY_COMPOSE_PROJECT=lihan_ai
DEPLOY_INCLUDE_CPA=0
DEPLOY_INCLUDE_CLOUDFLARE_TUNNEL=0
# Temporary fallback for patched New API frontend builds.
# Keep 0 for official image. Set 1 only while upstream official image lacks the dropdown onSelect fix.
DEPLOY_INCLUDE_LOCAL_NEW_API_BUILD=0
# build = compile vendor/new-api on this host; pull = pull LOCAL_NEW_API_IMAGE as a prebuilt patched image.
DEPLOY_LOCAL_NEW_API_BUILD_MODE=build
RELEASE_KEEP=5
ALLOW_NON_MAIN_PROD_DEPLOY=0
RUN_LIVE_E2E=0
SOURCE_SSH=
TARGET_SSH=
CONFIRM_FINAL_CUTOVER=no

# Optional Cloudflare for SaaS / custom-hostname verification.
# Keep DOMAIN as the public custom hostname, for example api.lihan3238.com.
# The fallback origin is only Cloudflare's route to this origin server.
CLOUDFLARE_SAAS_FALLBACK_ORIGIN=
CLOUDFLARE_SAAS_ORIGIN_IP=

# Optional Cloudflare Tunnel origin. Credentials stay on the production host.
# These paths must be regular files before starting the tunnel stack.
CLOUDFLARED_IMAGE=cloudflare/cloudflared:latest
CLOUDFLARED_CONFIG_PATH=/opt/lihan_ai_deploy/shared/cloudflared/config.yml
CLOUDFLARED_CREDENTIALS_PATH=/opt/lihan_ai_deploy/shared/cloudflared/tunnel.json

# Edge-only deployments use docker-compose.edge.yml and these variables.
EDGE_DOMAIN=api.example.com
ORIGIN_UPSTREAM=https://origin.example.com
