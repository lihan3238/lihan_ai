# Copy to .env.production on the production host.
# Replace every CHANGE_ME value before deployment.

DEPLOY_ENV=production
DEPLOY_COMPOSE_PROJECT=lihan_ai
LIHAN_AI_NETWORK=lihan_ai_relay-internal
TZ=Asia/Shanghai

NEW_API_IMAGE=calciumion/new-api:v1.0.0-rc.21@sha256:428018a37c0b26c163a3367c18401161707cd0e08d0f26a3dde9ff0caa05e34c
POSTGRES_IMAGE=postgres:15-alpine@sha256:3d0f7584ed7d04e27fa050d6683a74746608faf21f202be78460d679cc56461f
REDIS_IMAGE=redis:7-alpine@sha256:6ab0b6e7381779332f97b8ca76193e45b0756f38d4c0dcda72dbb3c32061ab99
CLI_PROXY_IMAGE=eceasy/cli-proxy-api:v7.2.67@sha256:00279b1ef92aa1edf2acb4d414e50502d8ba3a25f91cee0ec86615f272d4f505
CLOUDFLARED_IMAGE=cloudflare/cloudflared:2026.7.1@sha256:188bb03589a32affed3cf4d0590565ffe67b78866e6b5582574afab2b705bafe

NODE_NAME=relay-prod-origin-1
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_64_RANDOM_CHARS

POSTGRES_USER=newapi
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD_32_RANDOM_CHARS
POSTGRES_DB=newapi
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_32_RANDOM_CHARS

# CPA / CLIProxyAPI. Keep real config and auth files outside git.
CPA_CONFIG_PATH=/opt/lihan_ai_deploy/shared/data/cpa/config.yaml
CPA_AUTH_PATH=/opt/lihan_ai_deploy/shared/data/cpa
CPA_LOG_PATH=/opt/lihan_ai_deploy/shared/logs/cpa
CPA_BIND_IP=10.22.0.40
CPA_UI_PORT=8317
CPA_DEPLOY=

# Cloudflare Tunnel should be imported as a separate Komodo stack.
CLOUDFLARED_CONFIG_PATH=/opt/lihan_ai_deploy/shared/cloudflared/config.yml
CLOUDFLARED_CREDENTIALS_PATH=/opt/lihan_ai_deploy/shared/cloudflared/tunnel.json

# Backup output roots used by ops scripts.
BACKUP_DIR=/opt/lihan_ai_deploy/shared/backups
CONFIG_BACKUP_DIR=/opt/lihan_ai_deploy/shared/snapshots/config
BACKUP_AGE_RECIPIENT_FILE=/opt/lihan_ai_deploy/shared/backup-age-recipient.txt
