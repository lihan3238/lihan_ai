{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests"
  ],
  "dependencyDashboard": true,
  "timezone": "Asia/Singapore",
  "schedule": [
    "before 5am"
  ],
  "enabledManagers": [
    "docker-compose",
    "github-actions",
    "custom.regex"
  ],
  "pinDigests": true,
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^(?:\\.env(?:\\.production)?\\.example|docker-compose(?:\\.[a-z-]+)?\\.yml)$/"
      ],
      "matchStrings": [
        "(?<depName>calciumion/new-api|eceasy/cli-proxy-api|cloudflare/cloudflared|postgres|redis):(?<currentValue>[A-Za-z0-9._-]+)@(?<currentDigest>sha256:[0-9a-f]{64})"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/validate\\.yml$/"
      ],
      "matchStrings": [
        "--package renovate@(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "renovate",
      "datasourceTemplate": "npm"
    }
  ],
  "packageRules": [
    {
      "description": "Every major update requires explicit review",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "labels": [
        "dependencies",
        "manual-review"
      ]
    },
    {
      "description": "Database images require manual review",
      "groupName": "manual stateful database images",
      "matchPackageNames": [
        "postgres",
        "redis"
      ],
      "automerge": false,
      "labels": [
        "dependencies",
        "stateful",
        "manual-review"
      ]
    },
    {
      "description": "Cloudflared stays independent from relay updates",
      "matchPackageNames": [
        "cloudflare/cloudflared"
      ],
      "automerge": false,
      "labels": [
        "dependencies",
        "ingress",
        "manual-review"
      ]
    },
    {
      "description": "Validated New API and CLIProxyAPI patch, minor, and digest updates",
      "groupName": "fast relay images",
      "matchPackageNames": [
        "calciumion/new-api",
        "eceasy/cli-proxy-api"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor",
        "digest"
      ],
      "minimumReleaseAge": "6 hours",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "labels": [
        "dependencies",
        "relay"
      ]
    }
  ]
}
