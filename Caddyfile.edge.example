{
	email {$ACME_EMAIL}
}

{$EDGE_DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	reverse_proxy {$ORIGIN_UPSTREAM} {
		health_uri /api/status
		health_interval 30s
		health_timeout 5s
		flush_interval -1
	}
}
